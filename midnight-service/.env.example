# ─── midnight-service environment ────────────────────────────────────────────
#
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# ─── Network ──────────────────────────────────────────────────────────────────

# Which Midnight network to connect to.
# 'preview' → Midnight Preview network (default, public-hosted)
# 'preprod' → Midnight Preprod network (public-hosted, more stable)
MIDNIGHT_ENV=preview

# CORS: comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3006,http://127.0.0.1:3006,http://localhost:5173

# Port this service listens on.
PORT=3007
 
# ─── Contract deployment (on-chain mode only) ─────────────────────────────────
#
# When MIDNIGHT_ENV=preview or preprod, the deploy-contract.mjs script funds
# a server-side wallet from this seed and deploys the order_proof contract.
#
# NEVER commit real mainnet seeds here.  Use a separate throwaway seed for local dev.
# Generate one: node -e "import('@midnight-ntwrk/wallet-sdk-hd').then(m => console.log(m.generateMnemonic()))"
#
MIDNIGHT_WALLET_SEED=

# Address of the deployed order_proof contract (written by scripts/deploy-contract.mjs).
# Leave blank — the deploy script sets this automatically.
CONTRACT_ADDRESS=
