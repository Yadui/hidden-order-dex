# ── Azure OpenAI (optional — app uses mock AI if absent) ──────────────────────
# The mock fallback produces deterministic BUY/SELL/HOLD signals with no key.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── CORS (optional — defaults below match start.sh ports) ─────────────────────
# CORS_ORIGINS=http://localhost:3006,http://127.0.0.1:3006

# ── Encryption key (auto-generated on first run, do not share) ────────────────
# ORDERS_ENCRYPTION_KEY=   # generated automatically on first startup
