# ─── Frontend (Vite) environment ─────────────────────────────────────────────
#
# Copy this file to .env:
#   cp .env.example .env
#
# All variables must start with VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the midnight-service (localhost for local dev, deployed URL for prod).
VITE_MIDNIGHT_SERVICE_URL=http://localhost:3007

# Which Midnight network the frontend should describe in the UI.
# 'preview' → Midnight Preview network (default, public-hosted)
# 'preprod' → Midnight Preprod network (public-hosted, more stable)
VITE_MIDNIGHT_ENV=preview

# Backend (FastAPI) URL — used as the Vite dev-server proxy base.
# Usually empty (proxied) for local dev; set for production builds.
# VITE_BACKEND_URL=http://localhost:8006
